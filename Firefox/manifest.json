{
    "manifest_version": 2,
    "name": "AI Chat TOC",
    "version": "1.4.0",
    "description": "Adds a Table of Contents to ChatGPT, Gemini, Perplexity, Claude, and Grok",
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://www.perplexity.ai/*",
        "*://claude.ai/*",
        "*://grok.com/*",
        "*://x.com/*",
        "storage"
    ],
    "browser_action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://gemini.google.com/*",
                "*://www.perplexity.ai/*",
                "*://claude.ai/*",
                "*://grok.com/*",
                "*://x.com/*"
            ],
            "js": [
                "themes.js",
                "ui.js",
                "main.js"
            ],
            "css": [
                "style.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "ai-chat-toc@extension",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}